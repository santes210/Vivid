rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function postOwner() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function socialCountersOnly() {
      return signedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'followersCount',
          'followingCount',
          'likesCount',
          'commentsCount',
          'updatedAt'
        ]);
    }

    match /users/{userId} {
      allow read: if signedIn();

      // El dueño puede crear/editar su perfil.
      // También permitimos cambios de contadores sociales para que follow/unfollow funcione.
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (
        request.auth.uid == userId || socialCountersOnly()
      );

      match /followers/{docId} {
        allow read: if signedIn();
        // targetUser/followers/{currentUserId}
        allow create, delete: if signedIn() && docId == request.auth.uid;
      }

      match /following/{docId} {
        allow read: if signedIn();
        // currentUser/following/{targetUserId}
        allow create, delete: if signedIn() && request.auth.uid == userId;
      }
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;

      // El dueño puede editar todo su post.
      // Otros usuarios autenticados pueden tocar likes/comments count para que like/comentar funcione.
      allow update: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'likesCount',
          'commentsCount'
        ])
      );

      allow delete: if signedIn() && resource.data.userId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
      }
    }

    match /stories/{storyId} {
      // Nota: la app consulta stories activas en bloque y luego filtra privacidad del lado cliente.
      // Por eso, para esta versión, dejamos lectura a usuarios autenticados.
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /reels/{reelId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() && (
        resource.data.userId == request.auth.uid ||
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['likes'])
      );
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /chats/{chatId} {
      allow read: if signedIn() && request.auth.uid in resource.data.participants;
      allow create: if signedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if signedIn() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if signedIn()
          && request.resource.data.senderId == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow update: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }
  }
}
